[Unit]
ConditionPathExists=/kiosk
After=graphical.target keyme-manager.service
Description=KeyMe Control Panel (WebSocket + IPC for fleet/device control)

[Service]
Type=simple
User=kiosk
Group=kiosk
RestartSec=15
Restart=always
KillMode=process
KillSignal=SIGINT
ExecStop=/bin/sleep 0.1
Environment=PYTHONPATH=/kiosk
WorkingDirectory=/kiosk
ExecStart=/bin/bash -c 'PATH=/usr/venv/bin/:$PATH exec /kiosk/control_panel/python/main.py'

[Install]
WantedBy=graphical.target
