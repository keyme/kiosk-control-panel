[Unit]
ConditionPathExists=/kiosk
After=network-online.target
Description=KeyMe Control Panel (WebSocket + IPC for fleet/device control)

[Service]
Type=simple
User=kiosk
Group=kiosk
Restart=always
Nice=10
RestartSec=15
KillMode=process
KillSignal=SIGTERM
TimeoutStopSec=2
WorkingDirectory=/kiosk
Environment=PYTHONPATH=/kiosk
ExecStart=/usr/bin/python3 /kiosk/control_panel/python/main.py

[Install]
WantedBy=multi-user.target
